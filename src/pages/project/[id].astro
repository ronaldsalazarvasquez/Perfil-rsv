---
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';
import { projects } from '../../data/projects';
import '../../styles/global.css';

export function getStaticPaths() {
  return projects.map((project) => ({
    params: { id: project.id },
    props: { project },
  }));
}

const { project } = Astro.props;
---

<Layout 
  title={`${project.title} | Ronald Salazar`} 
  description={project.description}
  image={project.image}
>
  <main class="min-h-screen bg-gray-50 dark:bg-black pt-24 pb-20 px-4 relative overflow-hidden transition-colors duration-500">
    <!-- Blurs/Background -->
    <div class="absolute inset-0 overflow-hidden pointer-events-none z-0">
      <div class="absolute top-0 right-10 w-[600px] h-[600px] bg-emerald-600/5 dark:bg-emerald-600/10 rounded-full blur-[150px]"></div>
      <div class="absolute bottom-20 left-10 w-[500px] h-[500px] bg-cyan-600/5 rounded-full blur-[120px]"></div>
    </div>

    <div class="max-w-6xl mx-auto relative z-10">
      <!-- Back Button -->
      <a href="/" class="inline-flex items-center gap-2 text-gray-600 hover:text-emerald-500 dark:text-gray-400 dark:hover:text-emerald-400 transition-colors mb-12 group font-medium" style="font-family: var(--font-main);">
        <svg class="w-5 h-5 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
        Volver al Portafolio
      </a>

      <!-- Hero Section (Netflix Style) -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-10 lg:gap-16 mb-16 items-start project-header opacity-0 translate-y-12">
        
        <!-- Izquierda: Título y Sinopsis -->
        <div class="lg:col-span-4 flex flex-col order-2 lg:order-1 project-info">
          <div class="text-emerald-600 dark:text-emerald-400 text-xs font-semibold mb-2 font-mono tracking-wider uppercase">
            {project.subtitle}
          </div>
          <h1 class="text-3xl md:text-4xl font-extrabold mb-4 text-gray-900 dark:text-white tracking-tight leading-tight" style="font-family: var(--font-heading);">
            {project.title}
          </h1>
          
          <div class="flex flex-wrap gap-2 mb-6 project-tags">
            {project.tags.map((tag) => (
              <span class="px-2.5 py-1 bg-white dark:bg-white/5 text-gray-600 dark:text-gray-300 text-xs rounded-lg border border-gray-200 dark:border-white/10 font-medium shadow-sm dark:shadow-none" style="font-family: var(--font-main);">
                {tag}
              </span>
            ))}
          </div>

          <div class="text-gray-600 dark:text-gray-400 text-sm md:text-base leading-relaxed" style="font-family: var(--font-main);">
            <p>{project.longDescription}</p>
          </div>
        </div>

        <!-- Derecha: Media (Trailer) -->
        <div class="lg:col-span-8 order-1 lg:order-2 project-img opacity-0 scale-95 group relative w-full rounded-[2rem] overflow-hidden bg-black dark:bg-[#0a0a0a] border border-gray-200 dark:border-white/10 shadow-2xl">
          {project.gallery && project.gallery.length > 0 ? (
            <div id="project-carousel" class="flex overflow-x-auto snap-x snap-mandatory scroll-smooth w-full h-full aspect-[4/3] lg:aspect-video [&::-webkit-scrollbar]:hidden [-ms-overflow-style:none] [scrollbar-width:none]">
              {project.gallery.map((media, index) => {
                const isYouTube = media.type === 'video' && media.url.includes('youtu');
                let ytUrl = media.url;
                if (isYouTube) {
                  const videoId = media.url.includes('youtu.be/') 
                    ? media.url.split('youtu.be/')[1].split('?')[0] 
                    : media.url.split('v=')[1]?.split('&')[0];
                  ytUrl = `https://www.youtube.com/embed/${videoId}`;
                }
                return (
                  <div class="w-full h-full flex-shrink-0 snap-center relative">
                    {isYouTube ? (
                      <iframe 
                        src={ytUrl} 
                        title={`${project.title} Video`}
                        class="w-full h-full border-0 bg-black"
                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                        allowfullscreen
                      ></iframe>
                    ) : media.type === 'video' ? (
                      <video 
                        src={media.url} 
                        autoplay loop muted playsinline controls
                        class="w-full h-full object-cover bg-[#050505]"
                      />
                    ) : (
                      <img 
                        src={media.url} 
                        alt={`${project.title} - Galería ${index + 1}`} 
                        class="w-full h-full object-cover"
                        onerror={`this.src='data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800"%3E%3Crect fill="%23111" width="1200" height="800"/%3E%3Ctext x="50%25" y="50%25" dominant-baseline="middle" text-anchor="middle" font-family="monospace" font-size="40" fill="%2310b981"%3E${project.title}%3C/text%3E%3C/svg%3E'`}
                      />
                    )}
                  </div>
                );
              })}
            </div>
          ) : (
            <img 
              src={project.image} 
              alt={project.title} 
              class="w-full h-full aspect-[4/3] lg:aspect-video object-cover"
              onerror={`this.src='data:image/svg+xml,%3Csvg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 800"%3E%3Crect fill="%23111" width="1200" height="800"/%3E%3Ctext x="50%25" y="50%25" dominant-baseline="middle" text-anchor="middle" font-family="monospace" font-size="40" fill="%2310b981"%3E${project.title}%3C/text%3E%3C/svg%3E'`}
            />
          )}

          {project.gallery && project.gallery.length > 1 && (
            <>
              <button id="btn-prev" class="absolute left-4 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center rounded-full bg-black/40 hover:bg-black/70 text-white backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all border border-white/20 z-20" aria-label="Anterior">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
              </button>
              <button id="btn-next" class="absolute right-4 top-1/2 -translate-y-1/2 w-12 h-12 flex items-center justify-center rounded-full bg-black/40 hover:bg-black/70 text-white backdrop-blur-md opacity-0 group-hover:opacity-100 transition-all border border-white/20 z-20" aria-label="Siguiente">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/></svg>
              </button>
              
              <div class="absolute bottom-4 left-1/2 -translate-x-1/2 flex items-center gap-2 px-3 py-2 rounded-full bg-black/40 backdrop-blur-md border border-white/10 z-20">
                {project.gallery.map((_, i) => (
                  <button class={`carousel-dot w-2.5 h-2.5 rounded-full transition-all duration-300 ${i === 0 ? 'bg-emerald-500 scale-110' : 'bg-white/50 hover:bg-white/80'}`} data-index={i} aria-label={`Ir a la imagen ${i + 1}`}></button>
                ))}
              </div>
            </>
          )}
        </div>
      </div>

      <!-- Content Layout -->
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 lg:gap-16 project-content opacity-0 translate-y-12">
        <div class="lg:col-span-8">
          <div class="flex flex-col gap-5" style="font-family: var(--font-main);">
            <!-- El Desafío -->
            {project.problem && (
              <div class="p-6 md:p-8 rounded-[1.5rem] bg-white dark:bg-[#0a0a0a] border border-gray-100 dark:border-white/5 hover:border-gray-200 dark:hover:border-white/10 transition-colors shadow-sm flex flex-col sm:flex-row items-start gap-5 group">
                <div class="w-14 h-14 shrink-0 rounded-2xl bg-red-50 dark:bg-red-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <svg class="w-7 h-7 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
                </div>
                <div>
                  <h4 class="text-lg font-bold text-gray-900 dark:text-white mb-2" style="font-family: var(--font-heading);">
                    El Desafío
                  </h4>
                  <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm md:text-base">
                    {project.problem}
                  </p>
                </div>
              </div>
            )}

            <!-- La Solución -->
            {project.solution && (
              <div class="p-6 md:p-8 rounded-[1.5rem] bg-white dark:bg-[#0a0a0a] border border-gray-100 dark:border-white/5 hover:border-emerald-500/30 dark:hover:border-emerald-500/30 transition-colors shadow-sm flex flex-col sm:flex-row items-start gap-5 group">
                <div class="w-14 h-14 shrink-0 rounded-2xl bg-emerald-50 dark:bg-emerald-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <svg class="w-7 h-7 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                </div>
                <div>
                  <h4 class="text-lg font-bold text-gray-900 dark:text-white mb-2" style="font-family: var(--font-heading);">
                    La Solución
                  </h4>
                  <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm md:text-base">
                    {project.solution}
                  </p>
                </div>
              </div>
            )}

            <!-- Alcance y Resultados -->
            {project.scope && (
              <div class="p-6 md:p-8 rounded-[1.5rem] bg-white dark:bg-[#0a0a0a] border border-gray-100 dark:border-white/5 hover:border-blue-500/30 dark:hover:border-blue-500/30 transition-colors shadow-sm flex flex-col sm:flex-row items-start gap-5 group">
                <div class="w-14 h-14 shrink-0 rounded-2xl bg-blue-50 dark:bg-blue-500/10 flex items-center justify-center group-hover:scale-110 transition-transform">
                  <svg class="w-7 h-7 text-blue-600 dark:text-blue-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
                </div>
                <div>
                  <h4 class="text-lg font-bold text-gray-900 dark:text-white mb-2" style="font-family: var(--font-heading);">
                    Impacto y Resultados
                  </h4>
                  <p class="text-gray-500 dark:text-gray-400 leading-relaxed text-sm md:text-base">
                    {project.scope}
                  </p>
                </div>
              </div>
            )}
          </div>
        </div>

        <div class="lg:col-span-4 space-y-6 project-sidebar">
          <!-- Impact Badge -->
          <div class="bg-emerald-50 dark:bg-emerald-500/10 p-6 rounded-2xl border border-emerald-200 dark:border-emerald-500/20 shadow-sm flex items-center gap-4 project-feature-card">
             <div class="w-12 h-12 rounded-full bg-emerald-100 dark:bg-emerald-500/20 flex items-center justify-center shrink-0">
                <svg class="w-6 h-6 text-emerald-600 dark:text-emerald-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"/></svg>
             </div>
             <div>
                <h4 class="text-xs font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mb-1" style="font-family: var(--font-heading);">Impacto Logrado</h4>
                <p class="text-lg font-bold text-emerald-700 dark:text-emerald-400 leading-tight" style="font-family: var(--font-main);">{project.impact}</p>
             </div>
          </div>

          {project.features && project.features.length > 0 && (
            <div class="bg-white dark:bg-[#0a0a0a] p-6 rounded-2xl border border-gray-200 dark:border-white/10 shadow-lg dark:shadow-none project-feature-card">
              <h4 class="text-lg font-bold mb-4 text-gray-900 dark:text-white" style="font-family: var(--font-heading);">
                Características Clave
              </h4>
              <ul class="space-y-3">
                {project.features.map(feat => (
                  <li class="flex items-start gap-3 text-gray-600 dark:text-gray-400" style="font-family: var(--font-main);">
                    <svg class="w-5 h-5 text-emerald-500 mt-0.5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                    {feat}
                  </li>
                ))}
              </ul>
            </div>
          )}

          <div class="bg-white dark:bg-[#0a0a0a] flex flex-col p-6 rounded-2xl border border-gray-200 dark:border-white/10 shadow-lg dark:shadow-none project-status-card">
            {project.demoLink ? (
              <>
                <p class="text-gray-600 dark:text-gray-400 text-sm mb-4" style="font-family: var(--font-main);">
                  Este proyecto está en línea y puedes interactuar con él directamente.
                </p>
                <a href={project.demoLink} target="_blank" rel="noopener noreferrer" class="w-full text-center px-6 py-4 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-white font-bold transition-all hover:scale-[1.02] shadow-md hover:shadow-lg dark:hover:shadow-[0_0_20px_rgba(16,185,129,0.3)] flex items-center justify-center gap-2">
                  <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                  Visitar Demo en Vivo
                </a>
              </>
            ) : (
              <>
                <div class="flex items-center gap-3 mb-4">
                  <div class="w-10 h-10 rounded-full bg-orange-100 dark:bg-orange-500/20 flex items-center justify-center flex-shrink-0 border border-orange-200 dark:border-transparent">
                    <svg class="w-5 h-5 text-orange-600 dark:text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                  </div>
                  <h4 class="text-gray-900 dark:text-white font-bold" style="font-family: var(--font-heading);">Proyecto Local / Privado</h4>
                </div>
                <p class="text-gray-600 dark:text-gray-400 text-sm" style="font-family: var(--font-main);">
                  Por acuerdos de confidencialidad o despliegue en infraestructura interna, este proyecto no cuenta con una URL pública accesible.
                </p>
              </>
            )}
          </div>
        </div>
      </div>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  import gsap from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const tl = gsap.timeline({ defaults: { ease: 'back.out(1.5)' } });

    tl.to('.project-header', { y: 0, opacity: 1, duration: 1 })
      .fromTo('.project-tags span', 
        { scale: 0.8, opacity: 0 }, 
        { scale: 1, opacity: 1, stagger: 0.05, duration: 0.5, ease: 'back.out(2)' }, 
        "-=0.6"
      )
      .to('.project-img', 
        { scale: 1, opacity: 1, y: 0, stagger: 0.2, duration: 1, ease: 'back.out(1.2)' }, 
        "-=0.4"
      )
      .to('.project-content', { y: 0, opacity: 1, duration: 1, ease: 'power3.out' }, "-=0.6")
      .fromTo('.project-feature-card',
        { x: 30, opacity: 0 },
        { x: 0, opacity: 1, duration: 0.8, ease: 'back.out(1.2)' },
        "-=0.6"
      )
      .fromTo('.project-status-card',
        { x: 30, opacity: 0 },
        { x: 0, opacity: 1, duration: 0.8, ease: 'back.out(1.2)' },
        "-=0.7"
      );

    // Carousel Logic
    const carousel = document.getElementById('project-carousel');
    const btnPrev = document.getElementById('btn-prev');
    const btnNext = document.getElementById('btn-next');
    const dots = document.querySelectorAll('.carousel-dot');

    if (carousel && btnPrev && btnNext) {
      const updateDots = () => {
        const scrollLeft = carousel.scrollLeft;
        const width = carousel.clientWidth;
        const activeIndex = Math.round(scrollLeft / width);
        
        dots.forEach((dot, i) => {
          if (i === activeIndex) {
            dot.classList.remove('bg-white/50', 'hover:bg-white/80');
            dot.classList.add('bg-emerald-500', 'scale-110');
          } else {
            dot.classList.remove('bg-emerald-500', 'scale-110');
            dot.classList.add('bg-white/50', 'hover:bg-white/80');
          }
        });
      };

      carousel.addEventListener('scroll', updateDots, { passive: true });

      btnNext.addEventListener('click', () => {
        carousel.scrollBy({ left: carousel.clientWidth, behavior: 'smooth' });
      });

      btnPrev.addEventListener('click', () => {
        carousel.scrollBy({ left: -carousel.clientWidth, behavior: 'smooth' });
      });

      dots.forEach((dot) => {
        dot.addEventListener('click', (e) => {
          const index = parseInt((e.target as HTMLElement).dataset.index || '0');
          carousel.scrollTo({ left: index * carousel.clientWidth, behavior: 'smooth' });
        });
      });
    }
  });
</script>
