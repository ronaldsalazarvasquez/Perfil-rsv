---
interface Props {
  title: string;
  description?: string;
  image?: string;
}

const {
  title,
  description = "Ronald Salazar Vásquez - Software Engineer especializado en Industria 4.0, integración IT/OT, desarrollo de plataformas SaaS corporativas e Inteligencia Artificial aplicada.",
  image = "/images/projects/copiloto.webp" // Imagen por defecto para redes sociales
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site || Astro.url).href;
const socialImageURL = new URL(image, Astro.site || Astro.url).href;
---

<!doctype html>
<html lang="es" class="overflow-x-hidden overscroll-x-none">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <!-- Fuentes tipográficas -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800&family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Metadatos de SEO -->
    <meta name="author" content="Ronald Salazar Vásquez" />
    <meta name="keywords" content="Software Engineer, Industria 4.0, Integración IT/OT, Inteligencia Artificial, Internet of Things, IoT, SCADA, SaaS B2B, Ronald Salazar, Portafolio" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="sitemap" href="/sitemap-index.xml" />

    <!-- Tarjetas Open Graph (Facebook/LinkedIn) -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={socialImageURL} />

    <!-- Tarjetas de Twitter -->
    <meta property="twitter:card" content="summary_large_image" />
    <meta property="twitter:url" content={canonicalURL} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />
    <meta property="twitter:image" content={socialImageURL} />

    <!-- Datos estructurados para IA y SEO (AIO) -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "Person",
        "name": "Ronald Salazar Vásquez",
        "jobTitle": "Software Engineer | Industry 4.0 & AI",
        "url": "https://ronaldsalazar.dev",
        "sameAs": [
          "https://github.com/ronaldsalazarvasquez"
        ],
        "knowsAbout": [
          "Industria 4.0",
          "Internet of Things (IoT)",
          "Integración IT/OT",
          "Inteligencia Artificial Aplicada",
          "Desarrollo de SaaS B2B",
          "Sistemas SCADA y Telemetría"
        ]
      }
    </script>

    <title>{title}</title>
    
    <!-- Prevención de parpadeo (FOUC) del modo oscuro -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== 'undefined' && localStorage.getItem('manual-theme')) {
          return localStorage.getItem('manual-theme');
        }
        if (window.matchMedia('(prefers-color-scheme: dark)').matches) {
          return 'dark';
        }
        return 'light';
      })();

      if (theme === 'dark') {
        document.documentElement.classList.add('dark');
      } else {
        document.documentElement.classList.remove('dark');
      }
    </script>
  </head>
  <body class="antialiased overflow-x-hidden overscroll-x-none w-full transition-colors duration-500">
    <slot />

    <script>
      // Desplazamiento suave para enlaces ancla
      document.querySelectorAll('a[href^="#"]').forEach(anchor => {
        anchor.addEventListener('click', (e) => {
          e.preventDefault();
          const targetElement = e.currentTarget as HTMLAnchorElement;
          const href = targetElement.getAttribute('href');
          if (href) {
            const target = document.querySelector(href);
            if (target) {
              target.scrollIntoView({ behavior: 'smooth', block: 'start' });
            }
          }
        });
      });

      // Las animaciones al hacer scroll se configuran vía GSAP en los componentes.
    </script>
  </body>
</html>
