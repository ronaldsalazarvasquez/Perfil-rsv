---
---

<section id="contact" class="py-24 md:py-32 px-4 relative overflow-hidden">
  <!-- Background Decoration -->
  <div class="absolute inset-0 overflow-hidden pointer-events-none">
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[800px] h-[800px] bg-emerald-600/5 rounded-full blur-[150px]"></div>
  </div>

  <div class="max-w-4xl mx-auto relative z-10">
    <!-- Content Box -->
    <div class="glass dark:glass-dark bg-white dark:bg-transparent rounded-[3rem] p-10 md:p-16 border-[3px] border-gray-100 dark:border-emerald-500/20 text-center relative overflow-hidden shadow-2xl contact-container opacity-0 translate-y-12">
      <!-- Decorator overlay within card -->
      <div class="absolute top-0 right-0 w-64 h-64 bg-emerald-500/10 blur-[80px] rounded-full pointer-events-none"></div>

      <div class="relative z-10">
        <div class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full border border-gray-200 dark:border-white/10 bg-gray-50 dark:bg-white/5 text-gray-700 dark:text-gray-300 text-sm mb-8 font-bold shadow-sm">
          <span class="w-2.5 h-2.5 rounded-full bg-emerald-500 shadow-[0_0_10px_rgba(16,185,129,0.8)] animate-pulse"></span>
          Disponible para nuevos retos
        </div>

        <h2 class="text-4xl md:text-5xl font-extrabold mb-6 text-gray-900 dark:text-white tracking-tight" style="font-family: var(--font-heading);">
          ¿Listo para optimizar tu <br class="hidden md:block"/> entorno de trabajo?
        </h2>
        
        <p class="text-gray-600 dark:text-gray-400 text-lg md:text-xl max-w-2xl mx-auto mb-12 leading-relaxed font-medium" style="font-family: var(--font-main);">
          Hablemos de inmediato. No me gustan las esperas ni los formularios largos. Haz clic abajo para contactarme de forma directa y veamos cómo puedo aportar a tu equipo en tiempo real.
        </p>

        <!-- CTA Buttons -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-6">
          <!-- WhatsApp Button -->
          <a 
            href="https://wa.me/51998923495" 
            target="_blank" 
            rel="noopener noreferrer"
            class="group w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-5 rounded-[2rem] bg-emerald-500 text-white font-extrabold text-lg border-b-[6px] border-emerald-700 hover:border-b-[3px] hover:translate-y-[3px] active:border-b-0 active:translate-y-[6px] transition-all duration-150 shadow-lg"
            style="font-family: var(--font-main);"
          >
            <svg class="w-7 h-7 group-hover:scale-110 transition-transform" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
            </svg>
            Escribir por WhatsApp
          </a>

          <!-- Email Button -->
          <a 
            href="mailto:ronaldsalazarvasquez@gmail.com?subject=Propuesta%20/%20Oportunidad%20laboral&body=Hola%20Ronald,%20he%20visto%20tu%20perfil%20y%20me%20gustaría%20charlar%20contigo..." 
            class="group w-full sm:w-auto inline-flex items-center justify-center gap-3 px-8 py-5 rounded-[2rem] bg-gray-100 dark:bg-white/5 border-[3px] border-gray-200 dark:border-white/10 text-gray-900 dark:text-white font-extrabold text-lg border-b-[6px] hover:border-b-[3px] hover:translate-y-[3px] active:border-b-[2px] active:translate-y-[4px] transition-all duration-150 shadow-sm"
            style="font-family: var(--font-main);"
          >
            <svg class="w-6 h-6 text-emerald-500 group-hover:scale-110 group-hover:-rotate-12 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            Enviar Correo Directo
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    gsap.to('.contact-container', {
      scrollTrigger: {
        trigger: '#contact',
        start: 'top 80%',
      },
      y: 0,
      opacity: 1,
      duration: 1.2,
      ease: 'back.out(1.5)'
    });
  });
</script>
