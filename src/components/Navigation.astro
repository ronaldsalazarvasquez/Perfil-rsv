---
const navLinks = [
  { name: 'Inicio', href: '#home' },
  { name: 'Proyectos', href: '#projects' },
  { name: 'Tecnologías', href: '#technologies' },
  { name: 'Contacto', href: '#contact' }
];
---

<nav id="navbar" class="fixed top-0 left-0 right-0 z-50 transition-all duration-300">
  <div class="max-w-7xl mx-auto px-4 py-4">
    <div class="glass flex items-center justify-between" style="border-radius: 2rem; padding: 0.75rem 1.5rem;">
      <!-- Logo/Name -->
      <a href="#home" class="text-xl font-bold text-gray-800 dark:text-white hover:scale-105 hover:-translate-y-1 transition-transform" style="font-family: var(--font-pixel); font-size: 0.875rem;">
        RS
      </a>

      <!-- Desktop Navigation -->
      <div class="hidden md:flex items-center gap-8">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="text-gray-600 dark:text-gray-300 hover:text-emerald-500 transition-colors relative group font-semibold"
            style="font-family: var(--font-main);"
          >
            {link.name}
            <span class="absolute -bottom-1 left-0 w-0 h-0.5 bg-emerald-500 group-hover:w-full transition-all duration-300"></span>
          </a>
        ))}
      </div>

      <!-- Action Area -->
      <div class="hidden md:flex items-center gap-4">
        <!-- Theme Toggle -->
        <button id="theme-toggle" class="p-2.5 rounded-full bg-black/5 dark:bg-white/10 text-gray-800 dark:text-white hover:scale-110 active:scale-95 transition-all">
          <!-- Moon Icon (shows in light mode to switch to dark) -->
          <svg id="theme-toggle-dark-icon" class="hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
          </svg>
          <!-- Sun Icon (shows in dark mode to switch to light) -->
          <svg id="theme-toggle-light-icon" class="hidden w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="12" cy="12" r="5"></circle>
            <line x1="12" y1="1" x2="12" y2="3"></line>
            <line x1="12" y1="21" x2="12" y2="23"></line>
            <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line>
            <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line>
            <line x1="1" y1="12" x2="3" y2="12"></line>
            <line x1="21" y1="12" x2="23" y2="12"></line>
            <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line>
            <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line>
          </svg>
        </button>

        <!-- CTA Button -->
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-6 py-2.5 bg-emerald-500 text-white text-sm font-bold rounded-[2rem] border-b-[4px] border-emerald-700 hover:border-b-[2px] hover:translate-y-[2px] active:border-b-0 active:translate-y-[4px] transition-all"
          style="font-family: var(--font-main);"
        >
          <span>Contactar</span>
        </a>
      </div>

      <!-- Mobile Menu Button -->
      <button
        id="mobile-menu-button"
        class="md:hidden text-gray-800 dark:text-white p-2 hover:bg-black/5 dark:hover:bg-white/10 rounded-lg transition-colors"
        aria-label="Toggle menu"
      >
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="hidden md:hidden px-4 mt-2">
    <div class="glass rounded-[2rem] p-6 space-y-4 shadow-xl">
      <!-- Mobile Theme Toggle -->
      <button id="theme-toggle-mobile" class="w-full flex items-center justify-center gap-3 p-3 rounded-xl bg-black/5 dark:bg-white/10 text-gray-800 dark:text-white font-bold transition-all">
        <span class="dark-text hidden dark:inline">Modo Claro</span>
        <span class="light-text dark:hidden">Modo Oscuro</span>
      </button>

      {navLinks.map((link) => (
        <a
          href={link.href}
          class="block text-gray-600 dark:text-gray-300 font-bold py-3 px-4 hover:bg-black/5 dark:hover:bg-white/5 rounded-xl transition-all mobile-link text-center"
          style="font-family: var(--font-main);"
        >
          {link.name}
        </a>
      ))}
      <a
        href="#contact"
        class="block text-center px-6 py-4 bg-emerald-500 text-white font-bold rounded-[2rem] border-b-[4px] border-emerald-700 active:border-b-0 active:translate-y-[4px] transition-all mobile-link"
        style="font-family: var(--font-main);"
      >
        Contactar
      </a>
    </div>
  </div>
</nav>

<script>
  // Mobile menu toggle
  const mobileMenuButton = document.getElementById('mobile-menu-button');
  const mobileMenu = document.getElementById('mobile-menu');
  const mobileLinks = document.querySelectorAll('.mobile-link');

  mobileMenuButton?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });

  // Close mobile menu when clicking a link
  mobileLinks.forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu?.classList.add('hidden');
    });
  });

  // Theme Toggle Logic
  const themeToggleDarkIcon = document.getElementById('theme-toggle-dark-icon');
  const themeToggleLightIcon = document.getElementById('theme-toggle-light-icon');
  const themeToggleBtn = document.getElementById('theme-toggle');
  const themeToggleMobileBtn = document.getElementById('theme-toggle-mobile');

  // Set initial icon state based on the applied class (from Layout.astro script)
  const isDark = document.documentElement.classList.contains('dark');
  if (isDark) {
    themeToggleLightIcon?.classList.remove('hidden');
  } else {
    themeToggleDarkIcon?.classList.remove('hidden');
  }

  function toggleTheme() {
    // toggle icons
    themeToggleDarkIcon?.classList.toggle('hidden');
    themeToggleLightIcon?.classList.toggle('hidden');

    // if is dark -> go light
    if (document.documentElement.classList.contains('dark')) {
      document.documentElement.classList.remove('dark');
      localStorage.setItem('manual-theme', 'light');
    } else {
      // if is light -> go dark
      document.documentElement.classList.add('dark');
      localStorage.setItem('manual-theme', 'dark');
    }
  }

  themeToggleBtn?.addEventListener('click', toggleTheme);
  themeToggleMobileBtn?.addEventListener('click', toggleTheme);

  // Listen for system theme changes
  window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
    // Only automatically switch if user hasn't set a manual preference
    if (!localStorage.getItem('manual-theme')) {
      if (e.matches) {
        document.documentElement.classList.add('dark');
        themeToggleLightIcon?.classList.remove('hidden');
        themeToggleDarkIcon?.classList.add('hidden');
      } else {
        document.documentElement.classList.remove('dark');
        themeToggleLightIcon?.classList.add('hidden');
        themeToggleDarkIcon?.classList.remove('hidden');
      }
    }
  });

  // Navbar scroll effect
  const navbar = document.getElementById('navbar');
  let lastScroll = 0;

  window.addEventListener('scroll', () => {
    const currentScroll = window.pageYOffset;
    if (currentScroll <= 0) {
      navbar?.classList.remove('shadow-lg', 'shadow-black/10');
    } else {
      navbar?.classList.add('shadow-lg', 'shadow-black/10');
    }
    lastScroll = currentScroll;
  });

  // Close mobile menu when clicking outside
  document.addEventListener('click', (e) => {
    const target = e.target as HTMLElement;
    if (!target.closest('#mobile-menu') && !target.closest('#mobile-menu-button')) {
      mobileMenu?.classList.add('hidden');
    }
  });
</script>
