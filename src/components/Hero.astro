---
---

<section id="home" class="relative min-h-screen flex items-center justify-center overflow-hidden px-4 pt-24 md:pt-20">
  <!-- Interactive Grid Background -->
  <div class="absolute inset-0 pointer-events-none">
    <div class="absolute inset-0 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:24px_24px]"></div>
    <div class="absolute left-0 right-0 top-0 -z-10 m-auto h-[310px] w-[310px] rounded-full bg-emerald-500 opacity-[0.15] blur-[100px]"></div>
  </div>

  <div class="relative z-10 w-full max-w-7xl mx-auto flex flex-col lg:flex-row items-center justify-between gap-12 lg:gap-8">
    
    <!-- Text Content -->
    <div class="flex-1 w-full flex flex-col items-start text-left hero-content">
      <div class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full border border-emerald-500/30 bg-emerald-500/10 text-emerald-400 text-sm mb-6 font-medium hero-badge">
        <span class="w-2 h-2 rounded-full bg-emerald-500 animate-pulse"></span>
        Ingeniero de Sistemas e Informática
      </div>
      
      <h1 class="text-5xl md:text-6xl lg:text-7xl font-bold tracking-tight mb-6 text-gray-900 dark:text-white hero-title" style="font-family: var(--font-heading);">
        Ronald <br class="hidden md:block"/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-emerald-400 to-cyan-500">Salazar</span>
      </h1>
      
      <p class="text-lg md:text-xl text-gray-600 dark:text-gray-400 mb-10 max-w-2xl leading-relaxed hero-desc" style="font-family: var(--font-main);">
        Transformando sistemas industriales y procesos de negocio a través de <strong class="text-emerald-500 dark:text-emerald-400 font-bold">soluciones digitales innovadoras</strong>, análisis de datos e inteligencia artificial.
      </p>

      <div class="flex flex-col sm:flex-row flex-wrap gap-3 sm:gap-4 hero-actions w-full sm:w-auto max-w-sm sm:max-w-none">
        <a href="#projects" class="w-full sm:w-auto px-6 sm:px-8 py-3.5 sm:py-4 rounded-xl bg-emerald-500 hover:bg-emerald-600 text-gray-900 dark:text-white font-medium transition-all hover:scale-105 hover:shadow-[0_0_20px_rgba(16,185,129,0.4)] flex items-center justify-center gap-2">
          Ver Proyectos
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
        </a>
        <div class="grid grid-cols-2 gap-3 sm:flex sm:gap-4 w-full sm:w-auto">
          <a href="/CV-Ronald-Salazar.pdf" download class="w-full sm:w-auto px-2 sm:px-8 py-3.5 sm:py-4 rounded-xl glass hover:bg-gray-100 dark:hover:bg-white/5 text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white font-medium transition-all flex items-center justify-center gap-2 border border-gray-200 dark:border-white/10 text-sm sm:text-base text-center">
            Descargar CV
            <svg class="w-4 h-4 sm:w-5 sm:h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          </a>
          <a href="#contact" class="w-full sm:w-auto px-2 sm:px-8 py-3.5 sm:py-4 rounded-xl glass hover:bg-gray-100 dark:hover:bg-white/5 text-gray-700 dark:text-gray-300 hover:text-gray-900 dark:hover:text-white font-medium transition-all flex items-center justify-center gap-2 border border-gray-200 dark:border-white/10 text-sm sm:text-base text-center">
            Contactar
          </a>
        </div>
      </div>
    </div>

    <!-- Right Side Abstract/Glass Card -->
    <div class="flex-1 w-full max-w-lg lg:max-w-none relative hero-visuals">
      <!-- Main Glass Card -->
      <div class="glass dark:glass-dark bg-white/70 dark:bg-transparent p-8 rounded-2xl relative z-10 w-full overflow-hidden border border-gray-200 dark:border-emerald-500/20 shadow-xl dark:shadow-none">
        <div class="absolute inset-0 bg-gradient-to-br from-emerald-500/5 to-emerald-500/10 dark:from-emerald-500/10 dark:to-transparent opacity-50"></div>
        
        <div class="relative z-20">
          <div class="flex justify-between items-center mb-8 border-b border-gray-200 dark:border-white/10 pb-4">
            <div class="text-sm text-gray-600 dark:text-gray-400 font-mono font-bold">Impacto Industrial</div>
            <div class="flex gap-1.5">
              <div class="w-3 h-3 rounded-full bg-red-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-yellow-500/80"></div>
              <div class="w-3 h-3 rounded-full bg-emerald-500/80"></div>
            </div>
          </div>

          <!-- Radar Tooltip -->
          <div id="radar-tooltip" class="absolute pointer-events-none opacity-0 bg-white dark:bg-gray-900 text-gray-900 dark:text-white text-xs font-medium px-3 py-2 rounded-lg shadow-xl border border-gray-200 dark:border-emerald-500/30 w-48 z-50 transition-opacity duration-200" style="font-family: var(--font-main);">
            <div id="radar-tooltip-title" class="font-bold text-emerald-500 dark:text-emerald-400 mb-1 leading-tight"></div>
            <div id="radar-tooltip-desc" class="text-gray-600 dark:text-gray-300 leading-tight"></div>
          </div>

          <div class="relative w-full aspect-square max-w-[320px] mx-auto svg-radar-container">
            <svg viewBox="-30 -15 260 230" class="w-full h-full text-gray-900 dark:text-white overflow-visible" preserveAspectRatio="xMidYMid meet">
              <!-- Radial Lines -->
              <line x1="100" y1="100" x2="100" y2="30" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.2"/>
              <line x1="100" y1="100" x2="166.5" y2="78.4" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.2"/>
              <line x1="100" y1="100" x2="141.1" y2="156.6" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.2"/>
              <line x1="100" y1="100" x2="58.9" y2="156.6" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.2"/>
              <line x1="100" y1="100" x2="33.5" y2="78.4" stroke="currentColor" stroke-width="0.5" stroke-opacity="0.2"/>

              <!-- Concentric Pentagons (Grid) -->
              <!-- Layer 100% -->
              <polygon points="100,30 166.5,78.4 141.1,156.6 58.9,156.6 33.5,78.4" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity="0.1"/>
              <!-- Layer 75% -->
              <polygon points="100,47.5 149.8,83.8 130.8,142.4 69.1,142.4 50.1,83.8" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity="0.1"/>
              <!-- Layer 50% -->
              <polygon points="100,65 133.2,89.2 120.5,128.3 79.5,128.3 66.7,89.2" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity="0.1"/>
              <!-- Layer 25% -->
              <polygon points="100,82.5 116.6,94.6 110.2,114.1 89.8,114.1 83.3,94.6" fill="none" stroke="currentColor" stroke-width="1" stroke-opacity="0.1"/>

              <!-- Value Polygon (The Skills) -->
              <polygon id="radar-polygon" points="100,37 156.5,81.6 130.8,142.4 60.9,153.7 46.8,82.7" 
                fill="rgba(16, 185, 129, 0.4)" 
                stroke="#10b981" 
                stroke-width="2" 
                stroke-linejoin="round"
                class="filter drop-shadow-[0_0_8px_rgba(16,185,129,0.8)]"
              />

              <!-- Plot Points and interactive hotzones -->
              <g id="radar-points" fill="#10b981" class="stroke-white dark:stroke-[#111] opacity-90" stroke-width="1.5">
                <circle cx="100" cy="37" r="3" />
                <circle cx="156.5" cy="81.6" r="3" />
                <circle cx="130.8" cy="142.4" r="3" />
                <circle cx="60.9" cy="153.7" r="3" />
                <circle cx="46.8" cy="82.7" r="3" />
              </g>

              <!-- Interactive Hotzones with Labels -->
              <g class="radar-hotzone cursor-pointer" data-title="Mejora Continua" data-desc="Optimización lean y automatización CI/CD de procesos iterativos">
                <circle cx="100" cy="22" r="15" fill="transparent" />
                <text x="100" y="22" text-anchor="middle" font-size="9" font-weight="bold" fill="currentColor" opacity="0.9" class="hover:fill-emerald-500 transition-colors">Mejora Continua</text>
              </g>

              <g class="radar-hotzone cursor-pointer" data-title="Escalabilidad" data-desc="Diseño de arquitecturas modernas capaces de soportar altos flujos">
                <circle cx="171" cy="81" r="15" fill="transparent" />
                <text x="171" y="81" text-anchor="start" font-size="9" font-weight="bold" fill="currentColor" opacity="0.9" class="hover:fill-emerald-500 transition-colors">Escalabilidad</text>
              </g>

              <g class="radar-hotzone cursor-pointer" data-title="Análisis de Datos" data-desc="Extracción de valor de negocio mediante métricas y dashboards">
                <circle cx="145" cy="166" r="15" fill="transparent" />
                <text x="145" y="166" text-anchor="start" font-size="9" font-weight="bold" fill="currentColor" opacity="0.9" class="hover:fill-emerald-500 transition-colors">Análisis Datos</text>
              </g>

              <g class="radar-hotzone cursor-pointer" data-title="Optimización" data-desc="Aumento del rendimiento y refactorización de código legado">
                <circle cx="55" cy="166" r="15" fill="transparent" />
                <text x="55" y="166" text-anchor="end" font-size="9" font-weight="bold" fill="currentColor" opacity="0.9" class="hover:fill-emerald-500 transition-colors">Optimización</text>
              </g>

              <g class="radar-hotzone cursor-pointer" data-title="Resolución de Problemas" data-desc="Diagnóstico ágil de cuellos de botella y fallas críticas">
                <circle cx="29" cy="81" r="15" fill="transparent" />
                <text x="29" y="81" text-anchor="end" font-size="9" font-weight="bold" fill="currentColor" opacity="0.9" class="hover:fill-emerald-500 transition-colors">Resol. Problemas</text>
              </g>
            </svg>
          </div>

        <!-- Decorative Elements -->
        <div class="absolute -top-4 -right-4 w-24 h-24 bg-gradient-to-br from-emerald-400 to-cyan-500 rounded-full mix-blend-screen filter blur-xl opacity-50 animate-float"></div>
        <div class="absolute -bottom-8 -left-8 w-32 h-32 bg-gradient-to-tr from-indigo-500 to-purple-500 rounded-full mix-blend-screen filter blur-2xl opacity-40 animate-float" style="animation-delay: -2s;"></div>
      </div>
    </div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    // Reveal animations
    const tl = gsap.timeline({ defaults: { ease: 'back.out(1.5)' } });

    tl.fromTo('.hero-badge', 
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 }
    )
    .fromTo('.hero-title',
      { y: 40, opacity: 0 },
      { y: 0, opacity: 1, duration: 1 },
      "-=0.6"
    )
    .fromTo('.hero-desc',
      { y: 30, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      "-=0.6"
    )
    .fromTo('.hero-actions',
      { y: 20, opacity: 0 },
      { y: 0, opacity: 1, duration: 0.8 },
      "-=0.6"
    )
    .fromTo('.hero-visuals',
      { x: 50, opacity: 0 },
      { x: 0, opacity: 1, duration: 1.2 },
      "-=0.8"
    )
    .fromTo('#radar-polygon',
      { scale: 0, transformOrigin: '100px 100px' },
      { scale: 1, duration: 1.5, ease: 'back.out(2)' },
      "-=0.5"
    )
    .fromTo('#radar-points circle',
      { scale: 0, transformOrigin: 'center center' },
      { scale: 1, duration: 0.8, stagger: 0.1, ease: 'back.out(2)' },
      "-=1.0"
    );

    // Subtle floating animations for visuals
    gsap.to('.hero-visuals', {
      y: -15,
      duration: 3,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });

    // Tooltip logic
    const tooltip = document.getElementById('radar-tooltip');
    const tooltipTitle = document.getElementById('radar-tooltip-title');
    const tooltipDesc = document.getElementById('radar-tooltip-desc');
    const hotzones = document.querySelectorAll('.radar-hotzone');

    hotzones.forEach(zone => {
      zone.addEventListener('mouseenter', (e) => {
        if (!tooltip || !tooltipTitle || !tooltipDesc) return;
        const target = e.currentTarget as SVGElement;
        
        tooltipTitle.textContent = target.getAttribute('data-title') || '';
        tooltipDesc.textContent = target.getAttribute('data-desc') || '';
        
        tooltip.classList.remove('opacity-0');
        tooltip.classList.add('opacity-100');
      });

      zone.addEventListener('mousemove', (e) => {
        if (!tooltip) return;
        const mouseEvent = e as MouseEvent;
        // Position tooltip slightly offset from mouse
        tooltip.style.left = `${mouseEvent.pageX + 15}px`;
        tooltip.style.top = `${mouseEvent.pageY + 15}px`;
      });

      zone.addEventListener('mouseleave', () => {
        if (!tooltip) return;
        tooltip.classList.remove('opacity-100');
        tooltip.classList.add('opacity-0');
      });
    });
  });
</script>
